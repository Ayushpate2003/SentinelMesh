{
  "id": null,
  "uid": "sentinelmesh-overview",
  "title": "SentinelMesh Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(sentinelmesh_http_requests_total[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(sentinelmesh_errors_total[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Request Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(sentinelmesh_http_request_latency_seconds_bucket[5m])) by (le)) * 1000",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sentinelmesh_event_queue_depth", "refId": "A" }
      ]
    }
  ]
}
