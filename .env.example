# Gemini API Key (aistudio.google.com)
GOOGLE_API_KEY=your_gemini_api_key
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8002/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:8002

# VirusTotal API Key
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# Telegram Bot Token & Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Resend API Key & Notifications
RESEND_API_KEY=your_resend_api_key
ADMIN_EMAIL=your_admin_email@example.com

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_MEMORY=256mb

# Database Configuration
DATABASE_URL=sqlite:///sentinelmesh.db

# Runtime mode and simulation safety
LIGHT_MODE=false
SIMULATION_ENABLED=false
MAX_TESTS_PER_MINUTE=2
SIM_MAX_EVENTS=20
SIM_DELAY_SECONDS=0.2

# Reliability and backpressure
QUEUE_MAX_SIZE=1000
REQUEST_TIMEOUT_MS=500
IP_RATE_LIMIT_PER_MIN=120
EVENT_RATE_LIMIT_PER_MIN=60
CB_FAIL_THRESHOLD=3
CB_COOLDOWN_SECONDS=30

# Logging and observability
LOG_LEVEL=INFO
WORKER_METRICS_PORT=9101
ALERTMANAGER_URL=http://alertmanager:9093

# SLO thresholds and alerting controls
SLO_API_P95_MS_WARN=200
SLO_QUEUE_DEPTH_WARN=50
SLO_QUEUE_DEPTH_CRITICAL=100
SLO_DLQ_DEPTH_WARN=5
ALERT_COOLDOWN_SECONDS=120
